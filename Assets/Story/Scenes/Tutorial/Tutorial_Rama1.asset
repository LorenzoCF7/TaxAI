    actions: []
    music: {fileID: 0}
    sound: {fileID: 0}
  - text: 'Si. Se hacen pasar por sus victimas con el fin de acercarse a la especie
      humana con el fin de continuar un bucle sangriento sin fin. '
    speaker: {fileID: 11400000, guid: a5a6113b080e80f42995171e0e3df179, type: 2}
