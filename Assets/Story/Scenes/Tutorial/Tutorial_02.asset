%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 2cfa68ec4eee61e4eaced713bfacd37c, type: 3}
  m_Name: Tutorial_02
  m_EditorClassIdentifier: 
  sentences:
  - text: 'Como iba diciendo, en caso de que te encuentres a uno de estos "dobles"
      vas a tener que informar a la central directamente '
    speaker: {fileID: 11400000, guid: a5a6113b080e80f42995171e0e3df179, type: 2}
    actions: []
    music: {fileID: 0}
    sound: {fileID: 0}
  - text: 'En caso de no identificarlo se cobraran vidas inocentes por tu culpa,
      y quien sabe si la tuya puede caer por el camino... '
    speaker: {fileID: 11400000, guid: a5a6113b080e80f42995171e0e3df179, type: 2}
    actions: []
    music: {fileID: 0}
    sound: {fileID: 0}
  - text: "Aunque bueno, despu\xE9s de todo solo eres un par de cables y trozos de
      chapa "
    speaker: {fileID: 11400000, guid: a5a6113b080e80f42995171e0e3df179, type: 2}
    actions: []
    music: {fileID: 0}
    sound: {fileID: 0}
  - text: "En fin, para poder identificar a un doppelganger deberas identificar sus
      rasgos m\xE1s notorios "
    speaker: {fileID: 11400000, guid: a5a6113b080e80f42995171e0e3df179, type: 2}
    actions: []
    music: {fileID: 0}
    sound: {fileID: 0}
  - text: "(\u2026)"
    speaker: {fileID: 11400000, guid: daad6e1c9dd542b4794873f013a2b1b8, type: 2}
    actions: []
    music: {fileID: 0}
    sound: {fileID: 0}
  - text: "Los doppelganger pueden destacar por una actitud violenta sin m\xE1s,
      comentarios un tanto... especiales, malformaciones, movimientos y ruidos extra\xF1os
      y lo m\xE1s importante "
    speaker: {fileID: 11400000, guid: a5a6113b080e80f42995171e0e3df179, type: 2}
    actions: []
    music: {fileID: 0}
    sound: {fileID: 0}
  - text: 'Cambios en sus rasgos faciales '
    speaker: {fileID: 11400000, guid: a5a6113b080e80f42995171e0e3df179, type: 2}
    actions: []
    music: {fileID: 0}
    sound: {fileID: 0}
  - text: "\xBFCambios en sus rasgos faciales? "
    speaker: {fileID: 11400000, guid: daad6e1c9dd542b4794873f013a2b1b8, type: 2}
    actions: []
    music: {fileID: 0}
    sound: {fileID: 0}
  - text: "Si. Los doppelgangers como te he dicho anteriormente, capturan la apariencia
      de sus victimas en caso de pasar una cierta cantidad de tiempo sin cobrar una
      vida recuperar\xE1n su forma original "
    speaker: {fileID: 11400000, guid: a5a6113b080e80f42995171e0e3df179, type: 2}
    actions: []
    music: {fileID: 0}
    sound: {fileID: 0}
  background: {fileID: -1817558909277469638, guid: 3f012e31156587d429b0b8af95499fe4, type: 3}
  nextScene: {fileID: 11400000, guid: 4cb1e5236dc24944a92fdf6e3540a741, type: 2}
