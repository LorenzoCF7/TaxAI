  sentences:
  - text: A... mi casa... por rotten hills, cerca del viejo hospital
    speaker: {fileID: 11400000, guid: e1ecf9d1eea78ac4fb3ad850537f0c30, type: 2}
    actions: []
    music: {fileID: 0}
    sound: {fileID: 0}
  - text: "Pues all\xE1 vamos"
    speaker: {fileID: 11400000, guid: daad6e1c9dd542b4794873f013a2b1b8, type: 2}
    actions: []
    music: {fileID: 0}
    sound: {fileID: 0}
  - text: "(\u2026)"
    speaker: {fileID: 11400000, guid: daad6e1c9dd542b4794873f013a2b1b8, type: 2}
    actions: []
    music: {fileID: 0}
    sound: {fileID: 0}
  - text: Dios que dolor de cabeza... Todo me da vueltas...
    speaker: {fileID: 11400000, guid: e1ecf9d1eea78ac4fb3ad850537f0c30, type: 2}
    actions: []
    music: {fileID: 0}
    sound: {fileID: 0}
  - text: "\xBFCuantos a\xF1os tienes chaval?"
    speaker: {fileID: 11400000, guid: e1ecf9d1eea78ac4fb3ad850537f0c30, type: 2}
    actions: []
    music: {fileID: 0}
