  m_Script: {fileID: 11500000, guid: 2cfa68ec4eee61e4eaced713bfacd37c, type: 3}
  m_Name: Mario_Continuar
  m_EditorClassIdentifier: 
  sentences:
  - text: "Ughh\u2026 que dolor de cabeza..."
    speaker: {fileID: 11400000, guid: e1ecf9d1eea78ac4fb3ad850537f0c30, type: 2}
    actions: []
    music: {fileID: 0}
    sound: {fileID: 0}
  - text: Si tan solo tuviera un cuerpo joven, fuerte y ganas de vivir...
    speaker: {fileID: 11400000, guid: e1ecf9d1eea78ac4fb3ad850537f0c30, type: 2}
    actions: []
    music: {fileID: 0}
    sound: {fileID: 0}
  - text: "Espera... tu hab\xEDas dicho que eras joven \xBFverdad?..."
    speaker: {fileID: 11400000, guid: e1ecf9d1eea78ac4fb3ad850537f0c30, type: 2}
    actions: []
    music: {fileID: 0}
    sound: {fileID: 0}
  - text: "Ni\xF1ato de mierda... lo teneis TODO regalado, mi generaci\xF3n se lo
      ha currado todo para que gentuza como tu pueda vivir a sus anchas"
    speaker: {fileID: 11400000, guid: e1ecf9d1eea78ac4fb3ad850537f0c30, type: 2}
    actions: []
    music: {fileID: 0}
    sound: {fileID: 0}
  - text: "**Empiezas a escuchar un sonido muy raro detr\xE1s tuya**"
    speaker: {fileID: 11400000, guid: 96b6b3c89b136ee47a5b3c32f0e935df, type: 2}
    actions: []
    music: {fileID: 0}
    sound: {fileID: 0}
  - text: Creo... que no me encuentro muy bien...
    speaker: {fileID: 11400000, guid: e1ecf9d1eea78ac4fb3ad850537f0c30, type: 2}
    actions: []
    music: {fileID: 0}
    sound: {fileID: 0}
  - text: "Puedo bajarme por aqu\xED cerca... no contin\xFAes m\xE1s"
    speaker: {fileID: 11400000, guid: e1ecf9d1eea78ac4fb3ad850537f0c30, type: 2}
    actions: []
    music: {fileID: 0}
    sound: {fileID: 0}
  background: {fileID: 0}
  nextScene: {fileID: 11400000, guid: 24f28189d733f9f4f857c19f0c084119, type: 2}
